{
  "schema_version": "1.0",
  "id": "media-saber-mcp",
  "name": "Media Saber MCP",
  "version": "1.1.0",
  "author": "Media Saber",
  "license": "MIT",
  "description": "用于通过 MCP（streamable-http）控制 Media Saber 的 SkillHub 包，已准备好用于 OpenClaw 和兼容客户端。",
  "entry": "SKILL.md",
  "homepage": "https://wiki.msaber.fun/usage/ai/mcp.html",
  "tags": [
    "mcp",
    "media-saber",
    "openclaw",
    "claw",
    "subscription",
    "media"
  ],
  "runtime": {
    "protocol": "mcp",
    "transport": "streamable-http",
    "default_url": "<MCP_ENDPOINT_URL>",
    "auth": {
      "type": "header",
      "header": "Authorization",
      "format": "Bearer <API_KEY>"
    }
  },
  "files": [
    "SKILL.md",
    "docs/tool-reference.md",
    "examples/openclaw.mcpServers.json",
    "examples/claw-compatible.mcpServers.json"
  ]
}
